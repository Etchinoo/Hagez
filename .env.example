# ============================================================
# SUPER RESERVATION PLATFORM — Environment Variables
# Copy this file to .env and fill in values for local dev.
# NEVER commit .env to version control.
# ============================================================

# ── Node ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL 15) ─────────────────────────────────
# Local Docker: postgresql://postgres:postgres@localhost:5432/reservr_dev
# Staging/Prod: AWS RDS me-south-1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reservr_dev
DATABASE_SHADOW_URL=postgresql://postgres:postgres@localhost:5432/reservr_shadow

# ── Redis (ElastiCache / Docker) ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Paymob (Payment Gateway) ─────────────────────────────────
# Use Paymob Sandbox keys for development and staging
PAYMOB_API_KEY=your_paymob_api_key_here
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret_here
PAYMOB_INTEGRATION_ID_CARD=your_card_integration_id
PAYMOB_INTEGRATION_ID_FAWRY=your_fawry_integration_id
PAYMOB_INTEGRATION_ID_VODAFONE=your_vodafone_integration_id
PAYMOB_INTEGRATION_ID_INSTAPAY=your_instapay_integration_id
PAYMOB_INTEGRATION_ID_MEEZA=your_meeza_integration_id
PAYMOB_BASE_URL=https://accept.paymob.com/api

# ── 360dialog (WhatsApp Business API) ───────────────────────
DIALOG360_API_KEY=your_360dialog_api_key
DIALOG360_BASE_URL=https://waba.360dialog.io/v1
DIALOG360_WABA_NUMBER=+20xxxxxxxxxx

# ── Firebase (Push Notifications) ───────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── AWS SQS (Notification Queue) ────────────────────────────
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
SQS_NOTIFICATION_QUEUE_URL=https://sqs.me-south-1.amazonaws.com/xxxx/reservr-notifications
SQS_NOTIFICATION_DLQ_URL=https://sqs.me-south-1.amazonaws.com/xxxx/reservr-notifications-dlq

# ── AWS S3 (Media Storage) ───────────────────────────────────
S3_BUCKET_NAME=reservr-media
S3_BUCKET_REGION=me-south-1
CLOUDFRONT_DOMAIN=https://cdn.reservr.eg

# ── Google Maps ──────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Firebase Phone Auth ─────────────────────────────────────
FIREBASE_PROJECT_ID=hagez-9552a
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Sentry (Error Monitoring) ───────────────────────────────
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# ── OTP ─────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6

# ── Platform Fees (EGP) ─────────────────────────────────────
PLATFORM_FEE_RESTAURANT=25
PLATFORM_FEE_SALON=15
PLATFORM_FEE_COURT=35
PLATFORM_FEE_GAMING=20
PLATFORM_FEE_CAR_WASH=20

# ── Booking Engine ───────────────────────────────────────────
SLOT_HOLD_TTL_SECONDS=480
NO_SHOW_DETECTION_DELAY_MINUTES=30
CANCELLATION_WINDOW_DEFAULT_HOURS=24
NO_SHOW_SPLIT_BUSINESS_PCT=75
NO_SHOW_SPLIT_PLATFORM_PCT=25

# ── Consumer App (Expo) ──────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/v1
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key

# ── Dashboard (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/v1
