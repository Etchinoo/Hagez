# Normalize line endings to LF in the repo, checkout as-is on Windows
* text=auto eol=lf
*.bat text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.docx binary
*.xlsx binary
*.pptx binary
*.pdf binary
*.p12 binary
*.jks binary
