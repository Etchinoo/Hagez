# Production env for hagez-api container
# Copy to api.env on the server at /opt/hagez/env/api.env and fill in.
# NEVER commit api.env — only this .example file is committed.

NODE_ENV=production
PORT=3000

# Database — Supabase hagez-prod pooler
DATABASE_URL=postgres://postgres.pzlvjgeiinyryafchtzw:<PROD-PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Redis — runs as a sibling container in docker-compose
REDIS_URL=redis://redis:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=<32+ char random>
JWT_REFRESH_SECRET=<32+ char random>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# CORS — comma-separated origins that can hit this API
CORS_ORIGINS=https://hagez.app,https://www.hagez.app

# Firebase Phone Auth
FIREBASE_PROJECT_ID=hagez-9552a
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional integrations (fill in when ready)
# PAYMOB_API_KEY=
# PAYMOB_HMAC_SECRET=
# DIALOG360_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SENTRY_DSN=
