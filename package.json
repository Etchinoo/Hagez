{
  "name": "super-reservation",
  "version": "0.1.0",
  "private": true,
  "description": "Super Reservation Platform — Arabic-native multi-category lifestyle booking, Egypt Phase 1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "cd packages/api && npx prisma migrate dev",
    "db:generate": "cd packages/api && npx prisma generate",
    "db:studio": "cd packages/api && npx prisma studio",
    "db:seed": "cd packages/api && npx prisma db seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:tools": "docker compose --profile tools up -d",
    "docker:reset": "docker compose down -v && docker compose up -d"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "xlsx": "^0.18.5"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "tabWidth": 2
  }
}
